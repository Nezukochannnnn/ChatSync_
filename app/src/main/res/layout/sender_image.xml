<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="8dp"
    android:paddingEnd="48dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Sender Avatar (Perfect Circle) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/image_profile_sender"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_profile"
        android:scaleType="centerCrop"
        android:contentDescription="@string/content_description_profile"
        app:shapeAppearanceOverlay="@style/CircleImageView"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toBottomOf="@+id/card_sender_image"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Image Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_sender_image"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintStart_toEndOf="@+id/image_profile_sender"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/sender_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@string/attach_image" />
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>