<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="8dp"
    android:paddingEnd="48dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Sender Avatar -->
    <com.mikhaellopez.circularimageview.CircularImageView
        android:id="@+id/image_profile_sender"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_profile"
        android:contentDescription="@string/content_description_profile"
        app:civ_border_color="@color/primary"
        app:civ_border_width="1.5dp"
        app:layout_constraintBottom_toBottomOf="@+id/text_message_sender"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Sender Name -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_name_sender"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="2dp"
        android:text="John Doe"
        android:textColor="@color/primary_light"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/image_profile_sender"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Message Bubble -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_message_sender"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="2dp"
        android:background="@drawable/sender_bubble"
        android:maxWidth="280dp"
        android:padding="0dp"
        android:text="Hello! How are you?"
        android:textColor="@color/bubble_sender_text"
        android:textSize="15sp"
        android:lineSpacingExtra="2dp"
        app:layout_constraintStart_toEndOf="@+id/image_profile_sender"
        app:layout_constraintTop_toBottomOf="@+id/text_name_sender" />

    <!-- Timestamp -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_timestamp_sender"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="2dp"
        android:text="12:01 PM"
        android:textColor="@color/text_hint"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="@+id/text_message_sender"
        app:layout_constraintTop_toBottomOf="@+id/text_message_sender" />

</androidx.constraintlayout.widget.ConstraintLayout>