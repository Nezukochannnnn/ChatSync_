<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="48dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- My Avatar -->
    <com.mikhaellopez.circularimageview.CircularImageView
        android:id="@+id/image_profile_me"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_profile"
        android:scaleType="centerCrop"
        android:contentDescription="@string/content_description_profile"
        app:civ_border_color="@color/primary"
        app:civ_border_width="1.5dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toBottomOf="@+id/text_message_me"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Message Bubble -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_message_me"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:background="@drawable/me_bubble"
        android:maxWidth="250dp"
        android:padding="0dp"
        android:text="@string/hello_this_is_my_message"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:lineSpacingExtra="2dp"
        app:layout_constraintEnd_toStartOf="@+id/image_profile_me"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Timestamp -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_timestamp_me"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="2dp"
        android:text="@string/_12_00_pm"
        android:textColor="@color/text_hint"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="@+id/text_message_me"
        app:layout_constraintTop_toBottomOf="@+id/text_message_me" />

</androidx.constraintlayout.widget.ConstraintLayout>